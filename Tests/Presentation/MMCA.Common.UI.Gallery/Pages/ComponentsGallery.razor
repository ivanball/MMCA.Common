@page "/components"
@using MMCA.Common.UI.Components.Notifications

<PageTitle>Components</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
    <PageHeader Title="Components Gallery">
        <NotificationBell />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="ShowDeleteConfirmationAsync">
            Delete sample
        </MudButton>
    </PageHeader>

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Empty state</MudText>
    <MudPaper Outlined="true" Class="pa-2">
        <EmptyState Message="No records found." />
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Loading state</MudText>
    <MudPaper Outlined="true" Class="pa-2">
        <PageLoadingState Label="Loading sample data" />
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Error state</MudText>
    <MudPaper Outlined="true" Class="pa-2">
        <PageErrorState Message="Could not load the sample data." />
    </MudPaper>

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Mobile card list</MudText>
    <MobileCardList TItem="SampleItem" Items="_items" TotalItems="_items.Count" PageSize="10">
        <CardTemplate>
            <MudText Typo="Typo.subtitle2">@context.Name</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
        </CardTemplate>
    </MobileCardList>

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Mobile card list (empty)</MudText>
    <MobileCardList TItem="SampleItem" Items="_empty" TotalItems="0" PageSize="10"
                    EmptyMessage="Nothing to show yet.">
        <CardTemplate>
            <MudText>@context.Name</MudText>
        </CardTemplate>
    </MobileCardList>

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Unsaved-changes guard</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
        Dirty state: @(_isDirty ? "unsaved changes" : "clean")
    </MudText>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => _isDirty = !_isDirty)">
        Toggle unsaved changes
    </MudButton>
    <UnsavedChangesGuard IsDirty="_isDirty" />

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Mobile infinite-scroll list</MudText>
    <MobileInfiniteScrollList TItem="SampleItem" FetchPage="FetchSamplePageAsync" PageSize="3"
                              EmptyMessage="No items to show.">
        <CardTemplate>
            <MudText Typo="Typo.subtitle2">@context.Name</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.Description</MudText>
        </CardTemplate>
    </MobileInfiniteScrollList>

    <MudText Typo="Typo.h5" Class="mt-6 mb-2">Touch target affordance</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
        Icon buttons carrying the shared <c>mmca-touch-target</c> class meet the WCAG 2.5.5/2.5.8
        48px minimum hit area on mobile viewports.
    </MudText>
    <MudPaper Outlined="true" Class="pa-2">
        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                       Class="mmca-touch-target"
                       aria-label="Touch target sample"
                       Color="Color.Primary" />
    </MudPaper>
</MudContainer>

<DeleteConfirmation @ref="_deleteConfirmation" EntityType="Item" />

@code {
    private sealed record SampleItem(string Name, string Description);

    private readonly IReadOnlyList<SampleItem> _items =
    [
        new("First item", "A sample card rendered by MobileCardList."),
        new("Second item", "Another sample card with secondary text."),
        new("Third item", "Cards stack vertically on narrow viewports."),
    ];

    private readonly IReadOnlyList<SampleItem> _empty = [];

    private bool _isDirty;
    private DeleteConfirmation _deleteConfirmation = null!;

    private Task ShowDeleteConfirmationAsync() => _deleteConfirmation.ShowAsync("First item");

    private Task<(IReadOnlyList<SampleItem> Items, int TotalItems)> FetchSamplePageAsync(
        int page, int pageSize, CancellationToken cancellationToken)
        => Task.FromResult<(IReadOnlyList<SampleItem>, int)>((_items, _items.Count));
}
