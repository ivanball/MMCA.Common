@page "/not-found"
@layout MainLayout
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Page.NotFound.Title"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center mt-16">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large"
             Color="Color.Secondary" Style="font-size: 5rem;" Class="mb-4" />
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2">@L["Page.NotFound.Title"]</MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary" Class="mb-6">
        @L["Page.NotFound.Message"]
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Home"
               Href="/" Size="Size.Large">
        @L["Page.BackToHome"]
    </MudButton>
</MudContainer>
