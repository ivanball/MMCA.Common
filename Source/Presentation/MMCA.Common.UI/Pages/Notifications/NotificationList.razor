@page "/notifications"
@using MMCA.Common.Shared.Notifications.PushNotifications
@using MMCA.Common.UI.Common

<PageTitle>@Title</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 mb-2" />
<MudText Typo="Typo.h4" Class="mb-4">@Title</MudText>

<MudButton Color="Color.Primary"
           Variant="Variant.Filled"
           StartIcon="@Icons.Material.Filled.Send"
           OnClick="NavigateToSend"
           Class="mb-4">
    @L["Notif.List.SendNew"]
</MudButton>

@if (IsLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_notifications.Count == 0)
{
    <MudAlert Severity="Severity.Info" Class="mb-4">@L["Notif.List.Empty"]</MudAlert>
}
else
{
    <MudTable T="PushNotificationDTO"
              Items="_notifications"
              Dense="true"
              Hover="true"
              Elevation="1">
        <HeaderContent>
            <MudTh>@L["Notif.List.Col.Title"]</MudTh>
            <MudTh>@L["Notif.List.Col.Recipients"]</MudTh>
            <MudTh>@L["Notif.List.Col.Status"]</MudTh>
            <MudTh>@L["Notif.List.Col.Sent"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["Notif.List.Col.Title"]">@context.Title</MudTd>
            <MudTd DataLabel="@L["Notif.List.Col.Recipients"]">@context.RecipientCount</MudTd>
            <MudTd DataLabel="@L["Notif.List.Col.Status"]">
                @* Status comparisons stay on the wire value; only the display text localizes
                   (Notif.Status.* keys, raw value as fallback for unknown statuses). *@
                @if (context.Status == "Sent")
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">@DisplayStatus(context.Status)</MudChip>
                }
                else if (context.Status == "Failed")
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Outlined">@DisplayStatus(context.Status)</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">@DisplayStatus(context.Status)</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L["Notif.List.Col.Sent"]">@context.CreatedOn.ToString("g")</MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}
