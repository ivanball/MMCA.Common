@page "/notifications/send"
@using MMCA.Common.UI.Common

<PageTitle>@Title</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 mb-2" />
<MudText Typo="Typo.h4" Class="mb-4">@Title</MudText>

<MudCard Elevation="1" Class="mb-4 detail-card">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5">@L["Notif.Send.Compose"]</MudText>
            <MudText Typo="Typo.body2" Color="Color.Tertiary">
                @L["Notif.Send.Description"]
            </MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="_notificationTitle"
                          Label="@L["Notif.Send.Field.Title"]"
                          Required="true"
                          RequiredError="@L["Notif.Send.Field.Title.Required"]"
                          MaxLength="200"
                          Counter="200"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Class="mb-4" />

            <MudTextField @bind-Value="_notificationBody"
                          Label="@L["Notif.Send.Field.Message"]"
                          Required="true"
                          RequiredError="@L["Notif.Send.Field.Message.Required"]"
                          Lines="5"
                          MaxLength="2000"
                          Counter="2000"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Class="mb-4" />
        </MudForm>
    </MudCardContent>
    <MudCardActions>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Send"
                   OnClick="SendNotificationAsync"
                   Disabled="IsSaving">
            @(IsSaving ? L["Notif.Send.Sending"] : L["Notif.Send.SendToAll"])
        </MudButton>
        <MudButton Color="Color.Default"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="NavigateToList"
                   Disabled="IsSaving">
            @L["Common.Button.Cancel"]
        </MudButton>
    </MudCardActions>
</MudCard>
