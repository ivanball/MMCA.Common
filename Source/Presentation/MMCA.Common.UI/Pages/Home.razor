@page "/"
@using MMCA.Common.UI.Common.Interfaces
@inject IEnumerable<IHomePageContent> HomePageProviders

<PageTitle>@_pageTitle</PageTitle>

@if (_contentType is not null)
{
    <DynamicComponent Type="_contentType" />
}
else
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center" Style="min-height: 60vh;">
        <MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Large" Color="Color.Primary" Class="mb-4" />
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2">Welcome</MudText>
        <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
            Configure a home page by registering an <code>IHomePageContent</code> implementation.
        </MudText>
    </MudContainer>
}

@code {
    private Type? _contentType;
    private string _pageTitle = "Home";

    protected override void OnInitialized()
    {
        var provider = HomePageProviders.FirstOrDefault();
        if (provider is not null)
        {
            _contentType = provider.ComponentType;
            _pageTitle = provider.PageTitle;
        }
    }
}
