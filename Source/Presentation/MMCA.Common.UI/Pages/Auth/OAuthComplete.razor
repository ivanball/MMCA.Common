@page "/auth/oauth-complete"
@using MMCA.Common.UI.Services.Auth
@using MMCA.Common.UI.Services.Navigation
@attribute [StreamRendering(false)]
@inject IAuthUIService AuthService
@inject NavigationManager Navigation

<PageTitle>Completing sign in...</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="auth-container">
    <div class="d-flex flex-column align-center">
        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login">
                Back to Login
            </MudButton>
        }
        else
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.body1" Class="mt-4">Completing sign in...</MudText>
        }
    </div>
</MudContainer>

@code {
    // The OAuth complete endpoint mints a single-use code and carries it here in the URL —
    // the access/refresh tokens are exchanged out-of-band (POST auth/oauth/exchange) so they
    // never appear in the address bar, browser history, Referer header, or server logs.
    [SupplyParameterFromQuery]
    public string? Code { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        if (!string.IsNullOrEmpty(Error))
        {
            _error = $"Authentication failed: {Error}";
            StateHasChanged();
            return;
        }

        if (string.IsNullOrEmpty(Code))
        {
            _error = "Authentication failed: missing exchange code.";
            StateHasChanged();
            return;
        }

        try
        {
            var result = await AuthService.ExchangeOAuthCodeAsync(Code);
            if (result is null)
            {
                _error = AuthService.LastError ?? "Failed to complete sign in. Please try again.";
                StateHasChanged();
                return;
            }

            Navigation.NavigateTo(ReturnUrlProtector.Sanitize(ReturnUrl, "/"), forceLoad: true);
        }
        catch
        {
            _error = "Failed to complete sign in. Please try again.";
            StateHasChanged();
        }
    }
}
