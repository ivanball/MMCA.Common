@page "/login"
@using Microsoft.Extensions.Options
@using MMCA.Common.Shared.Auth
@using MMCA.Common.UI.Common.Settings
@using MMCA.Common.UI.Services.Auth
@using MMCA.Common.UI.Services.Navigation
@attribute [StreamRendering(false)]
@inject IAuthUIService AuthService
@inject IOAuthUISettings OAuthSettings
@inject IOptions<ApiSettings> ApiSettingsOptions
@inject NavigationManager Navigation
@inject IUserPreferenceReader PreferenceReader
@inject ThemeService ThemeService

<PageTitle>Login</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="auth-container">
    <div class="d-flex flex-column align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large"
                 Color="Color.Primary" Class="mb-2" />
        <MudText Typo="Typo.h4" Align="Align.Center">Welcome Back</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
            Sign in to your account to continue
        </MudText>
    </div>

    <MudCard Elevation="1">
        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
            <DataAnnotationsValidator />
            <MudCardContent Class="pa-6">
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
                }
                <MudTextField @bind-Value="_model.Email" For="@(() => _model.Email)" Label="Email" InputType="InputType.Email"
                              Immediate="true"
                              Variant="Variant.Outlined" Class="mb-4"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Email"
                              autocomplete="email" />
                <MudTextField @bind-Value="_model.Password" For="@(() => _model.Password)" Label="Password" InputType="InputType.Password"
                              Immediate="true"
                              Variant="Variant.Outlined" Class="mb-2"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Key"
                              autocomplete="current-password" />
            </MudCardContent>
            <MudCardActions Class="d-flex flex-column pa-6 pt-0" Style="gap: 0.75rem;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Disabled="@_isLoading" ButtonType="ButtonType.Submit" Size="Size.Large"
                           aria-label="Sign in to your account">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Sign In
                </MudButton>
                <MudDivider Class="my-1" />
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                    Don't have an account?
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           Href="/register" Size="Size.Medium">
                    Create Account
                </MudButton>
                @if (_hasExternalProviders)
                {
                    <MudDivider Class="my-1" />
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        Or continue with
                    </MudText>
                    @if (OAuthSettings.GoogleEnabled)
                    {
                        <MudButton Variant="Variant.Outlined" FullWidth="true" Size="Size.Medium"
                                   StartIcon="@Icons.Custom.Brands.Google"
                                   Href="@BuildOAuthUrl("google")"
                                   aria-label="Sign in with Google">
                            Sign in with Google
                        </MudButton>
                    }
                    @if (OAuthSettings.GitHubEnabled)
                    {
                        <MudButton Variant="Variant.Outlined" FullWidth="true" Size="Size.Medium"
                                   StartIcon="@Icons.Custom.Brands.GitHub"
                                   Href="@BuildOAuthUrl("github")"
                                   aria-label="Sign in with GitHub">
                            Sign in with GitHub
                        </MudButton>
                    }
                }
            </MudCardActions>
        </EditForm>
    </MudCard>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly LoginModel _model = new();
    private string? _errorMessage;
    private bool _isLoading;
    private bool _hasExternalProviders;
    private string _apiBase = string.Empty;

    protected override void OnInitialized()
    {
        _hasExternalProviders = OAuthSettings.GoogleEnabled || OAuthSettings.GitHubEnabled;
        _apiBase = ApiSettingsOptions.Value.ApiEndpoint?.TrimEnd('/') ?? string.Empty;
    }

    private string BuildOAuthUrl(string provider)
    {
        var url = $"{_apiBase}/auth/oauth/{provider}";
        var safeReturnUrl = ReturnUrlProtector.Sanitize(ReturnUrl, "/");
        if (!string.Equals(safeReturnUrl, "/", StringComparison.Ordinal))
        {
            url += $"?returnUrl={Uri.EscapeDataString(safeReturnUrl)}";
        }
        return url;
    }

    private async Task HandleLoginAsync()
    {
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var result = await AuthService.LoginAsync(new LoginRequest(_model.Email, _model.Password));
            if (result is not null)
            {
                await ApplyStoredPreferencesAndNavigateAsync(ReturnUrlProtector.Sanitize(ReturnUrl, "/"));
            }
            else
            {
                _errorMessage = AuthService.LastError ?? "Invalid email or password.";
            }
        }
        catch
        {
            _errorMessage = "An error occurred during login. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    // Applies the signed-in user's stored culture/theme (ADR-027/028) once, right after login, so the
    // preference follows them across devices. Best-effort: an empty/failed read just navigates normally.
    // Loop-free because this only runs on the explicit login action.
    private async Task ApplyStoredPreferencesAndNavigateAsync(string destination)
    {
        var preferences = await PreferenceReader.GetAsync();

        if (preferences.Theme is not null)
        {
            await ThemeService.SetDarkModeAsync(string.Equals(preferences.Theme, "dark", StringComparison.OrdinalIgnoreCase));
        }

        if (preferences.Culture is not null
            && !string.Equals(preferences.Culture, System.Globalization.CultureInfo.CurrentUICulture.Name, StringComparison.OrdinalIgnoreCase))
        {
            // Route through /culture/set to write the culture cookie, then reload to the destination.
            Navigation.NavigateTo(
                $"/culture/set?culture={Uri.EscapeDataString(preferences.Culture)}&redirectUri={Uri.EscapeDataString(destination)}",
                forceLoad: true);
            return;
        }

        Navigation.NavigateTo(destination, forceLoad: true);
    }
}
