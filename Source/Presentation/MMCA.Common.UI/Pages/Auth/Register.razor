@page "/register"
@using MMCA.Common.Shared.Auth
@using MMCA.Common.Shared.ValueObjects
@using MMCA.Common.UI.Services.Auth
@attribute [StreamRendering(false)]
@inject IAuthUIService AuthService
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Auth.Register.PageTitle"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="auth-container">
    <div class="d-flex flex-column align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Large"
                 Color="Color.Primary" Class="mb-2" />
        <MudText Typo="Typo.h4" Align="Align.Center">@L["Auth.Register.Title"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
            @* Generic subtitle (ADR-027): the previous literal was ADC-conference copy leaking into
               every consumer of this shared page. *@
            @L["Auth.Register.Subtitle"]
        </MudText>
    </div>

    <MudCard Elevation="1">
        <EditForm Model="_model" OnValidSubmit="HandleRegisterAsync">
            <DataAnnotationsValidator />
            <MudCardContent Class="pa-6">
                @if (!string.IsNullOrWhiteSpace(_errorMessage))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
                }
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_model.FirstName" For="@(() => _model.FirstName)" Label="@L["Auth.Field.FirstName"]"
                                      Immediate="true"
                                      Variant="Variant.Outlined"
                                      autocomplete="given-name" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_model.LastName" For="@(() => _model.LastName)" Label="@L["Auth.Field.LastName"]"
                                      Immediate="true"
                                      Variant="Variant.Outlined"
                                      autocomplete="family-name" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Email" For="@(() => _model.Email)" Label="@L["Auth.Field.Email"]" InputType="InputType.Email"
                                      Immediate="true"
                                      Variant="Variant.Outlined"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.Email"
                                      autocomplete="email" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_model.Password" For="@(() => _model.Password)" Label="@L["Auth.Field.Password"]" InputType="InputType.Password"
                                      Immediate="true"
                                      HelperText="@L["Auth.Register.PasswordHelper"]"
                                      Variant="Variant.Outlined"
                                      autocomplete="new-password" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_model.ConfirmPassword" For="@(() => _model.ConfirmPassword)" Label="@L["Auth.Field.ConfirmPassword"]" InputType="InputType.Password"
                                      Immediate="true"
                                      Variant="Variant.Outlined"
                                      autocomplete="new-password" />
                    </MudItem>
                </MudGrid>

                <MudExpansionPanels Class="mt-4" Elevation="0">
                    <MudExpansionPanel Text="@L["Auth.Register.AddressOptional"]">
                        <MudGrid Spacing="3">
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_model.AddressLine1" Label="@L["Auth.Field.AddressLine1"]"
                                              Variant="Variant.Outlined" autocomplete="address-line1" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="_model.AddressLine2" Label="@L["Auth.Field.AddressLine2"]"
                                              Variant="Variant.Outlined" autocomplete="address-line2" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_model.City" Label="@L["Auth.Field.City"]"
                                              Variant="Variant.Outlined" autocomplete="address-level2" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_model.State" Label="@L["Auth.Field.State"]"
                                              Variant="Variant.Outlined" autocomplete="address-level1" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_model.ZipCode" Label="@L["Auth.Field.ZipCode"]"
                                              Variant="Variant.Outlined" autocomplete="postal-code" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_model.Country" Label="@L["Auth.Field.Country"]"
                                              Variant="Variant.Outlined" autocomplete="country-name" />
                            </MudItem>
                        </MudGrid>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </MudCardContent>
            <MudCardActions Class="d-flex flex-column pa-6 pt-2" Style="gap: 0.75rem;">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Disabled="@_isLoading" ButtonType="ButtonType.Submit" Size="Size.Large"
                           aria-label="@L["Auth.Register.CreateAccount.Aria"]">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    @L["Auth.Register.CreateAccount"]
                </MudButton>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                    @L["Auth.Register.AlreadyHaveAccount"]
                    @* Underline.Always: an in-text link must be distinguishable without relying on colour
                       alone (WCAG 2.1 AA / axe link-in-text-block). *@
                    <MudLink Href="/login" Typo="Typo.body2" Underline="Underline.Always">@L["Auth.Register.SignIn"]</MudLink>
                </MudText>
            </MudCardActions>
        </EditForm>
    </MudCard>
</MudContainer>

@code {
    private readonly RegisterModel _model = new();
    private string? _errorMessage;
    private bool _isLoading;

    private Address? BuildAddress()
    {
        if (string.IsNullOrWhiteSpace(_model.AddressLine1))
            return null;

        var result = Address.Create(_model.AddressLine1, _model.AddressLine2, _model.City, _model.State, _model.ZipCode, _model.Country);
        return result.IsSuccess ? result.Value : null;
    }

    private async Task HandleRegisterAsync()
    {
        // Field-level rules (required, email, password complexity, password match) are enforced by the
        // EditForm + DataAnnotations before OnValidSubmit fires; this method only handles the call and
        // any server-side failure, surfaced in the form-level MudAlert.
        _errorMessage = null;
        _isLoading = true;

        try
        {
            var result = await AuthService.RegisterAsync(
                new RegisterRequest(_model.Email, _model.Password, _model.FirstName, _model.LastName, BuildAddress()));
            if (result is not null)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _errorMessage = AuthService.LastError ?? L["Auth.Register.Failed"];
            }
        }
        catch
        {
            _errorMessage = L["Auth.Register.GenericError"];
        }
        finally
        {
            _isLoading = false;
        }
    }
}
