@page "/register"
@using MMCA.Common.Shared.Auth
@using MMCA.Common.Shared.ValueObjects
@using MMCA.Common.UI.Services.Auth
@attribute [StreamRendering(false)]
@inject IAuthUIService AuthService
@inject NavigationManager Navigation

<PageTitle>Create Account</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="auth-container">
    <div class="d-flex flex-column align-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Size="Size.Large"
                 Color="Color.Primary" Class="mb-2" />
        <MudText Typo="Typo.h4" Align="Align.Center">Create Account</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
            Join the Atlanta Cloud + AI Conference community
        </MudText>
    </div>

    <MudCard Elevation="1">
        <MudCardContent Class="pa-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
            }
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_firstName" Label="First Name"
                                  Immediate="true" Required="true" RequiredError="First name is required"
                                  Variant="Variant.Outlined"
                                  autocomplete="given-name" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_lastName" Label="Last Name"
                                  Immediate="true" Required="true" RequiredError="Last name is required"
                                  Variant="Variant.Outlined"
                                  autocomplete="family-name" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_email" Label="Email" InputType="InputType.Email"
                                  Immediate="true" Required="true" RequiredError="Email is required"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  autocomplete="email" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_password" Label="Password" InputType="InputType.Password"
                                  Immediate="true" Required="true" RequiredError="Password is required"
                                  HelperText="Min 8 chars, with uppercase, lowercase, digit, and special character"
                                  Variant="Variant.Outlined"
                                  autocomplete="new-password" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password" InputType="InputType.Password"
                                  Immediate="true" Required="true" RequiredError="Please confirm your password"
                                  Variant="Variant.Outlined"
                                  autocomplete="new-password" />
                </MudItem>
            </MudGrid>

            <MudExpansionPanels Class="mt-4" Elevation="0">
                <MudExpansionPanel Text="Address (Optional)">
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_addressLine1" Label="Address Line 1"
                                          Variant="Variant.Outlined" autocomplete="address-line1" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_addressLine2" Label="Address Line 2"
                                          Variant="Variant.Outlined" autocomplete="address-line2" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_city" Label="City"
                                          Variant="Variant.Outlined" autocomplete="address-level2" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_state" Label="State"
                                          Variant="Variant.Outlined" autocomplete="address-level1" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_zipCode" Label="Zip Code"
                                          Variant="Variant.Outlined" autocomplete="postal-code" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_country" Label="Country"
                                          Variant="Variant.Outlined" autocomplete="country-name" />
                        </MudItem>
                    </MudGrid>
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column pa-6 pt-2" Style="gap: 0.75rem;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       Disabled="@_isLoading" OnClick="HandleRegisterAsync" Size="Size.Large"
                       aria-label="Create your account">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Create Account
            </MudButton>
            <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                Already have an account?
                <MudLink Href="/login" Typo="Typo.body2">Sign In</MudLink>
            </MudText>
        </MudCardActions>
    </MudCard>
</MudContainer>

@code {
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _addressLine1 = string.Empty;
    private string? _addressLine2;
    private string? _city;
    private string? _state;
    private string? _zipCode;
    private string? _country;
    private string? _errorMessage;
    private bool _isLoading;

    private Address? BuildAddress()
    {
        if (string.IsNullOrWhiteSpace(_addressLine1))
            return null;

        var result = Address.Create(_addressLine1, _addressLine2, _city, _state, _zipCode, _country);
        return result.IsSuccess ? result.Value : null;
    }

    private async Task HandleRegisterAsync()
    {
        _errorMessage = null;

        if (_password != _confirmPassword)
        {
            _errorMessage = "Passwords do not match.";
            return;
        }

        if (_password.Length < 8)
        {
            _errorMessage = "Password must be at least 8 characters.";
            return;
        }

        if (!_password.Any(char.IsUpper) || !_password.Any(char.IsLower) ||
            !_password.Any(char.IsDigit) || _password.All(char.IsLetterOrDigit))
        {
            _errorMessage = "Password must contain uppercase, lowercase, a digit, and a special character.";
            return;
        }

        _isLoading = true;

        try
        {
            var result = await AuthService.RegisterAsync(
                new RegisterRequest(_email, _password, _firstName, _lastName, BuildAddress()));
            if (result is not null)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                _errorMessage = AuthService.LastError ?? "Registration failed. Please try again.";
            }
        }
        catch
        {
            _errorMessage = "An error occurred during registration. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }
}
