@using Microsoft.AspNetCore.Components.Authorization
@using MMCA.Common.UI.Common.Interfaces
@using MMCA.Common.UI.Pages
@inject IEnumerable<IUIModule> UIModules

<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Layout.MainLayout).Assembly"
            AdditionalAssemblies="UIModules.Select(m => m.Assembly)"
            NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                <Authorizing>
                    <MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-center mt-16">
                        <MudProgressCircular Indeterminate="true" aria-label="Checking authorization" />
                    </MudContainer>
                </Authorizing>
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        @* Authenticated but lacking the required role/permission → a dedicated 403
                           page rendered in the app shell (rubric §25), not a bare alert. *@
                        <Forbidden />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>
