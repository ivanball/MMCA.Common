@inject IStringLocalizer<SharedResource> L

<div class="d-flex flex-column align-center pa-6">
    <MudIcon Icon="@Icon" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
    <MudText Typo="Typo.subtitle1" Color="Color.Secondary"><em>@(Message ?? L["Common.EmptyState.NoRecords"])</em></MudText>
</div>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.SearchOff;

    /// <summary>Empty-state text; defaults to the localized "No records found." (ADR-027).</summary>
    [Parameter] public string? Message { get; set; }
}
