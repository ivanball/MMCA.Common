@using MMCA.Common.UI.Services.Navigation
@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var current = "/" + Navigation.ToBaseRelativePath(Navigation.Uri);
        var safeReturnUrl = ReturnUrlProtector.Sanitize(current, "/");
        var target = string.Equals(safeReturnUrl, "/", StringComparison.Ordinal)
            ? "/login"
            : $"/login?returnUrl={Uri.EscapeDataString(safeReturnUrl)}";
        Navigation.NavigateTo(target, forceLoad: true);
    }
}
