<div role="status" aria-live="polite" aria-busy="true">
    @* role="status" makes this a live region (a bare div may not carry aria-label, WCAG 4.1.2); the
       spinner itself carries the accessible name so the progressbar is not anonymous. *@
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" Class="my-4"
                         aria-label="@Label" />
</div>

@code {
    [Parameter] public string Label { get; set; } = "Loading";
}
