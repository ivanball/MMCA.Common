@*
    Wraps Blazor's <NavigationLock> to provide a unified guard against losing
    unsaved form/page state across every navigation surface:

      - browser back / forward / tab close → ConfirmExternalNavigation triggers
        the native beforeunload dialog (uncustomisable, but uniformly supported)
      - in-app NavigateTo / nav links → OnBeforeInternalNavigation shows a
        MudDialog with a custom message that the user can confirm or cancel

    Set IsDirty to true when the form is modified, false on save/discard.
*@
@using Microsoft.AspNetCore.Components.Routing
@inject IDialogService DialogService
@inject IStringLocalizer<SharedResource> L

<NavigationLock ConfirmExternalNavigation="@CurrentIsDirty"
                OnBeforeInternalNavigation="HandleBeforeInternalNavigationAsync" />

@code {
    /// <summary>
    /// When <see langword="true"/>, in-app navigation away from this component is
    /// intercepted with a confirmation dialog and external navigation triggers the
    /// browser's <c>beforeunload</c> prompt.
    /// </summary>
    [Parameter, EditorRequired] public bool IsDirty { get; set; }

    /// <summary>
    /// Optional live accessor for the current dirty state. When provided, it is consulted at
    /// navigation time instead of <see cref="IsDirty"/>, avoiding the one-render parameter lag
    /// where clearing dirty state and calling <c>NavigateTo</c> without an intervening
    /// <c>StateHasChanged()</c> would still show the prompt. Pass <c>() =&gt; _isDirty</c> from the parent.
    /// </summary>
    [Parameter] public Func<bool>? IsDirtyAccessor { get; set; }

    private bool CurrentIsDirty => IsDirtyAccessor?.Invoke() ?? IsDirty;

    /// <summary>Title of the in-app confirmation dialog; defaults to the localized text (ADR-027).</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Body text of the in-app confirmation dialog; defaults to the localized text (ADR-027).</summary>
    [Parameter] public string? Message { get; set; }

    /// <summary>Label of the primary (leave) button; defaults to the localized text (ADR-027).</summary>
    [Parameter] public string? LeaveButtonText { get; set; }

    /// <summary>Label of the secondary (stay) button; defaults to the localized text (ADR-027).</summary>
    [Parameter] public string? StayButtonText { get; set; }

    private async Task HandleBeforeInternalNavigationAsync(LocationChangingContext context)
    {
        if (!CurrentIsDirty)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBoxAsync(
            Title ?? L["UnsavedChanges.Title"],
            Message ?? L["UnsavedChanges.Message"],
            yesText: LeaveButtonText ?? L["UnsavedChanges.Leave"],
            cancelText: StayButtonText ?? L["UnsavedChanges.Stay"]);

        if (confirmed is not true)
        {
            context.PreventNavigation();
        }
    }
}
