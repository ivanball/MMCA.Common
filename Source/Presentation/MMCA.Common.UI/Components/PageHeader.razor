<div class="page-header">
    @* HtmlTag="h1" gives the page its required level-one heading (axe page-has-heading-one) while keeping h4 styling. *@
    <MudText Typo="Typo.h4" HtmlTag="h1">@Title</MudText>
    <MudSpacer />
    @ChildContent
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
