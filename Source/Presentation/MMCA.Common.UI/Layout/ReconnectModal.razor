@* Blazor Server / InteractiveAuto reconnect UX (hoisted from the app hosts, byte-identical there).
   The collocated JS module now ships as a static web asset of this RCL, so the asset key carries the
   _content/{PackageId} prefix. *@
@inject IStringLocalizer<SharedResource> L
<script type="module" src="@Assets["_content/MMCA.Common.UI/Layout/ReconnectModal.razor.js"]"></script>

<dialog id="components-reconnect-modal" data-nosnippet>
    <div class="components-reconnect-container">
        <div class="components-rejoining-animation" aria-hidden="true">
            <div></div>
            <div></div>
        </div>
        <p class="components-reconnect-first-attempt-visible">
            @L["Reconnect.Rejoining"]
        </p>
        <p class="components-reconnect-repeated-attempt-visible">
            @* Split around the countdown span whose content Blazor's reconnect JS writes by id;
               the two keys are documented as one sentence in the resx (ADR-027). *@
            @L["Reconnect.RetryPrefix"] <span id="components-seconds-to-next-attempt"></span> @L["Reconnect.RetrySuffix"]
        </p>
        <p class="components-reconnect-failed-visible">
            @L["Reconnect.Failed"]<br />@L["Reconnect.FailedAction"]
        </p>
        <button id="components-reconnect-button" class="components-reconnect-failed-visible">
            @L["Common.Button.Retry"]
        </button>
        <p class="components-pause-visible">
            @L["Reconnect.Paused"]
        </p>
        <button id="components-resume-button" class="components-pause-visible">
            @L["Reconnect.Resume"]
        </button>
        <p class="components-resume-failed-visible">
            @L["Reconnect.ResumeFailed"]<br />@L["Reconnect.ResumeFailedAction"]
        </p>
    </div>
</dialog>
