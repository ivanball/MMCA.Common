@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using MMCA.Common.UI.Common.Interfaces
@using MMCA.Common.UI.Pages.Common
@using MMCA.Common.UI.Services.Auth
@using Microsoft.Extensions.Options
@using MMCA.Common.UI.Common.Settings
@using MMCA.Common.UI.Theme
@inject NavigationManager Navigation
@inject IAuthUIService AuthService
@inject IEnumerable<IUIModule> UIModules
@inject IOptions<LayoutSettings> LayoutSettingsOptions
@inject IStringLocalizer<SharedResource> L
@inject ThemeService ThemeService
@implements IDisposable

<MudThemeProvider Theme="MMCATheme.Instance" @bind-IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<a href="#main-content" class="skip-nav">@L["Layout.SkipToMainContent"]</a>

<div class="page">
    <aside class="sidebar" aria-label="Main navigation">
        @* Complementary landmark wraps the whole sidebar so ALL of it — including NavMenu's brand top-row
           that sits above the inner <nav> — is contained by a landmark (axe region, best-practice). No
           role="navigation" on the <aside>: the inner NavMenu already renders the <nav>, and an <aside>
           may not carry that role (axe aria-allowed-role). *@
        <NavMenu />
    </aside>

    <main role="main">
        <div class="appbar-container">
            <MudAppBar Elevation="1" Dense="true" Fixed="false" aria-label="Top navigation bar">
                <div class="appbar-spacer"></div>
                @* Culture + theme controls are available to everyone, authenticated or not. *@
                <span class="appbar-icon-actions">
                    <CultureSwitcher />
                    <ThemeToggle />
                </span>
                <AuthorizeView>
                    <Authorized>
                        <span class="appbar-auth-items">
                            <span class="appbar-icon-actions">
                                @foreach (var componentType in _appBarComponents)
                                {
                                    <DynamicComponent Type="componentType" />
                                }
                            </span>
                            <MudText Typo="Typo.body2" Class="mr-4 user-name">@context.User.Identity?.Name</MudText>
                            <span class="appbar-text-actions">
                                <MudButton Variant="Variant.Text" Color="Color.Inherit" OnClick="HandleLogoutAsync"
                                           aria-label="@L["Common.Button.Logout.Aria"].Value">@L["Common.Button.Logout"]</MudButton>
                            </span>
                        </span>
                    </Authorized>
                    <NotAuthorized>
                        <span class="appbar-auth-items">
                            <span class="appbar-text-actions">
                                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">@L["Common.Button.Login"]</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/register">@L["Common.Button.Register"]</MudButton>
                            </span>
                        </span>
                    </NotAuthorized>
                </AuthorizeView>
            </MudAppBar>
        </div>
        <article id="main-content" class="content px-4">
            @Body
        </article>
    </main>
    @* The contentinfo (footer) landmark must be top-level, not nested inside <main> (axe landmark-contentinfo-is-top-level). *@
    @if (!string.IsNullOrWhiteSpace(LayoutSettingsOptions.Value.FooterText))
    {
        <footer class="app-footer" role="contentinfo">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                @LayoutSettingsOptions.Value.FooterText
            </MudText>
        </footer>
    }
    @foreach (var componentType in _layoutComponents)
    {
        <DynamicComponent Type="componentType" />
    }
</div>

<div id="blazor-error-ui" data-nosnippet role="alert">
    @L["Layout.UnhandledError"]
    <a href="." class="reload">@L["Layout.Reload"]</a>
    <span class="dismiss">X</span>
</div>

@code {
    private bool _isDarkMode;
    private List<Type> _appBarComponents = [];
    private List<Type> _layoutComponents = [];

    protected override void OnInitialized()
    {
        _appBarComponents = UIModules.SelectMany(m => m.AppBarComponentTypes).ToList();
        _layoutComponents = UIModules.SelectMany(m => m.LayoutComponentTypes).ToList();

        // Back the static ErrorMessages helper with the shared localizer (ADR-027). The layout renders for
        // every page in both Server and WASM, so this configures it once per circuit/host.
        ErrorMessages.Configure(L);
        ThemeService.OnChange += OnThemeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // JS interop (cookie/localStorage read) is only available after the first interactive render.
            await ThemeService.InitializeAsync();
            _isDarkMode = ThemeService.IsDarkMode;
            StateHasChanged();
        }
    }

    private void OnThemeChanged(object? sender, EventArgs e)
    {
        _isDarkMode = ThemeService.IsDarkMode;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => ThemeService.OnChange -= OnThemeChanged;

    private async Task HandleLogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
