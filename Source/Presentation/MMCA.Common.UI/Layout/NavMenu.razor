@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Options
@using MMCA.Common.UI.Common
@using MMCA.Common.UI.Common.Interfaces
@using MMCA.Common.UI.Common.Settings
@using MMCA.Common.UI.Services.Auth
@inject IEnumerable<IUIModule> UIModules
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthUIService AuthService
@inject NavigationManager Navigation
@inject IOptions<LayoutSettings> LayoutSettingsOptions
@inject IStringLocalizer<SharedResource> L
@inject IStringLocalizerFactory LocalizerFactory

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="@RoutePaths.Home" aria-label="@L["Nav.BrandHome.Aria", LayoutSettingsOptions.Value.BrandName]">@LayoutSettingsOptions.Value.BrandName</a>
    </div>
    <AuthorizeView>
        <Authorized>
            <div class="toprow-actions" aria-label="@L["Nav.QuickActions.Aria"]">
                @foreach (var componentType in _appBarComponents)
                {
                    <DynamicComponent Type="componentType" />
                }
                <span class="toprow-user-name" title="@context.User.Identity?.Name">@context.User.Identity?.Name</span>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

<input type="checkbox" title="@L["Nav.ToggleMenu.Aria"]" class="navbar-toggler"
       aria-label="@L["Nav.ToggleMenu.Aria"]" aria-expanded="false"
       aria-controls="nav-menu" />

<div class="nav-backdrop" aria-hidden="true"></div>

<nav id="nav-menu" class="nav-scrollable" aria-label="@L["Nav.SiteNavigation.Aria"]">
    <MudNavMenu Color="Color.Default">
        <MudNavLink Href="@RoutePaths.Home" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">@L["Nav.Home"]</MudNavLink>

        @foreach (var group in _generalItems.GroupBy(i => i.Group))
        {
            if (group.Key is not null)
            {
                <MudNavGroup Title="@DisplayGroup(group)" Icon="@Icons.Material.Filled.Folder" Expanded="false">
                    @foreach (var item in group)
                    {
                        <MudNavLink Href="@item.Href" Icon="@item.Icon">@Display(item)</MudNavLink>
                    }
                </MudNavGroup>
            }
            else
            {
                @foreach (var item in group)
                {
                    <MudNavLink Href="@item.Href" Icon="@item.Icon">@Display(item)</MudNavLink>
                }
            }
        }

        @if (_userItems.Count > 0 && _user?.Identity?.IsAuthenticated == true)
        {
            <div class="nav-section-label" role="heading" aria-level="2">@L["Nav.MyAccount"]</div>
            @foreach (var group in _userItems.GroupBy(i => i.Group))
            {
                if (group.Key is not null)
                {
                    <MudNavGroup Title="@DisplayGroup(group)" Icon="@Icons.Material.Filled.Folder" Expanded="false">
                        @foreach (var item in group)
                        {
                            <MudNavLink Href="@item.Href" Icon="@item.Icon">@Display(item)</MudNavLink>
                        }
                    </MudNavGroup>
                }
                else
                {
                    @foreach (var item in group)
                    {
                        <MudNavLink Href="@item.Href" Icon="@item.Icon">@Display(item)</MudNavLink>
                    }
                }
            }
        }

        @if (_adminItems.Count > 0)
        {
            <div class="nav-section-label" role="heading" aria-level="2">@L["Nav.Administration"]</div>
            @foreach (var group in _adminItems.GroupBy(i => i.Group))
            {
                if (group.Key is not null)
                {
                    <MudNavGroup Title="@DisplayGroup(group)" Icon="@Icons.Material.Filled.Folder" Expanded="false">
                        @foreach (var item in group)
                        {
                            <MudNavLink Href="@item.Href" Icon="@item.Icon">@Display(item)</MudNavLink>
                        }
                    </MudNavGroup>
                }
                else
                {
                    @foreach (var item in group)
                    {
                        <MudNavLink Href="@item.Href" Icon="@item.Icon">@Display(item)</MudNavLink>
                    }
                }
            }
        }
    </MudNavMenu>

    <div class="nav-auth-section">
        <AuthorizeView>
            <Authorized>
                <div class="nav-user-identity">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Size="Size.Small" />
                    <MudText Typo="Typo.body2">@context.User.Identity?.Name</MudText>
                </div>
                <MudNavMenu Color="Color.Default">
                    <MudNavLink Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogoutAsync">@L["Common.Button.Logout"]</MudNavLink>
                </MudNavMenu>
            </Authorized>
            <NotAuthorized>
                <MudNavMenu Color="Color.Default">
                    <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">@L["Common.Button.Login"]</MudNavLink>
                    <MudNavLink Href="/register" Icon="@Icons.Material.Filled.PersonAdd">@L["Common.Button.Register"]</MudNavLink>
                </MudNavMenu>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private ClaimsPrincipal? _user;
    private List<Type> _appBarComponents = [];
    private List<NavItem> _generalItems = [];
    private List<NavItem> _userItems = [];
    private List<NavItem> _adminItems = [];

    // ADR-027: items carrying a TitleResource treat Title/Group as resource keys resolved at render
    // time against that type's resx pair, so the menu follows the active culture; items without one
    // (or with a missing key) render the raw string, keeping literal-titled modules working unchanged.
    private string Display(NavItem item)
    {
        if (item.TitleResource is null)
        {
            return item.Title;
        }

        var localized = LocalizerFactory.Create(item.TitleResource)[item.Title];
        return localized.ResourceNotFound ? item.Title : localized.Value;
    }

    private string DisplayGroup(IGrouping<string?, NavItem> group)
    {
        var first = group.FirstOrDefault(i => i.TitleResource is not null);
        if (group.Key is null || first is null)
        {
            return group.Key ?? string.Empty;
        }

        var localized = LocalizerFactory.Create(first.TitleResource!)[group.Key];
        return localized.ResourceNotFound ? group.Key : localized.Value;
    }

    private async Task HandleLogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        _appBarComponents = UIModules.SelectMany(m => m.AppBarComponentTypes).ToList();

        var allItems = UIModules
            .SelectMany(m => m.NavItems)
            .Where(item => item.RequiredRole is null || _user?.IsInRole(item.RequiredRole) == true)
            .Where(item => item.RequiredClaim is null || _user?.HasClaim(c => c.Type == item.RequiredClaim) == true)
            .ToList();

        _generalItems = allItems.Where(i => i.Section is NavSection.General).ToList();
        _userItems = allItems.Where(i => i.Section is NavSection.User).ToList();
        _adminItems = allItems.Where(i => i.Section is NavSection.Admin).ToList();
    }
}
