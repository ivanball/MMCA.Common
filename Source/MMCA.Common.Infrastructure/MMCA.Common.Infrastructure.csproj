<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>MMCA.Common.Infrastructure</PackageId>
    <Description>MMCA framework — EF Core multi-DB, repositories, UoW, caching, JWT, outbox</Description>
  </PropertyGroup>
