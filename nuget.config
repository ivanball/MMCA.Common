<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Supply-chain hardening: restrict every package to nuget.org via package source mapping so a
    typosquatted or dependency-confusion package from another feed cannot be silently substituted.
    MMCA.Common consumes only public nuget.org packages (it *publishes* the MMCA.Common.* packages
    rather than consuming them), so a single `*` -> nuget.org mapping is correct here.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
